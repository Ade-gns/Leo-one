# Leo-One RMM — Variables d'environnement (valeurs de développement)
# Copier ce fichier en .env : cp .env.example .env
# NE PAS committer .env (il contient des secrets)

# ── Application ─────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=dev

# ── Serveur ─────────────────────────────────────────────────────
SERVER_ADDR=0.0.0.0:8080
WS_AGENT_ADDR=0.0.0.0:8081

# ── Base de données ─────────────────────────────────────────────
# En développement local (Go lancé directement) : localhost:5432
# En Docker (profile full) : remplacer localhost par postgres
DATABASE_URL=postgres://leo:leo_dev@localhost:5432/leo_one?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ── JWT (HS256) ──────────────────────────────────────────────────
# CHANGER EN PRODUCTION (minimum 32 caractères)
JWT_SECRET=dev-secret-change-in-production-min-32-chars!!

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=debug
